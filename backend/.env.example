APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Replace with your trained YOLOv8 smoke detection model.
MODEL_PATH=weights/best.pt
ALLOW_FALLBACK_MODEL=true
FALLBACK_MODEL_NAME=yolov8n.pt

DEFAULT_CONFIDENCE_THRESHOLD=0.20
MAX_UPLOAD_SIZE_MB=100
SMOKE_CLASS_NAMES=smoke

# Comma-separated frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional MongoDB
MONGO_URI=
MONGO_DB_NAME=vehicle_emission
MONGO_COLLECTION_NAME=detections
